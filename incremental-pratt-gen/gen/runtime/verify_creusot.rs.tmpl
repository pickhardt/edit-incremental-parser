//! GENERATED Creusot unbounded certificate for grammar `/*@GRAMMAR@*/`.
//!
//! The four-part precedence-bounded reuse predicate (Definition 3.3) with
//! Creusot contracts. `cargo creusot` translates this to Why3 and discharges
//! the verification conditions via SMT (Z3 / Alt-Ergo), proving the
//! operational predicate equals its declarative specification over `Seq<u8>`
//! of ANY length — the unbounded counterpart of the Kani harnesses.
//!
//! The macros are no-ops under plain `cargo build`/`test`; only `cargo
//! creusot` activates them. The only grammar-specific pieces are
//! `lbp_of_byte_logic` and the operational `next_token_lbp` (condition 4),
//! specialised by the generator to this grammar's single-byte operators.

#![allow(unused)]

use creusot_std::{
    logic::{Int, Seq},
    prelude::{ensures, logic, pearlite, requires, trusted, variant},
};

/// Cached subtree reuse metadata.
#[derive(Clone, Copy)]
#[cfg_attr(creusot, derive(creusot_std::model::DeepModel))]
pub struct VNode {
    pub start: usize,
    pub end: usize,
    pub m_spine: u32,
    pub stop_lbp: u32,
}

/// Replace `[start, start+removed)` with `added` bytes.
#[derive(Clone, Copy)]
#[cfg_attr(creusot, derive(creusot_std::model::DeepModel))]
pub struct VEdit {
    pub start: usize,
    pub added: usize,
    pub removed: usize,
}

// ---- Logic-level specification of Definition 3.3 -----------------------

#[logic(open)]
pub fn translate_logic(edit: VEdit, old_pos: Int) -> Option<Int> {
    pearlite! {
        if old_pos < edit.start@ {
            Some(old_pos)
        } else if old_pos >= edit.start@ + edit.removed@ {
            Some(old_pos + edit.added@ - edit.removed@)
        } else {
            None
        }
    }
}

#[logic(open)]
pub fn byte_at(src: Seq<u8>, pos: Int) -> Option<u8> {
    pearlite! { if 0 <= pos && pos < src.len() { Some(src[pos]) } else { None } }
}

#[logic(open)]
pub fn byte_at_opt(src: Seq<u8>, pos: Option<Int>) -> Option<u8> {
    pearlite! { match pos { Some(p) => byte_at(src, p), None => None } }
}

/// Condition (1): two-sided precedence band.
#[logic(open)]
pub fn cond_precedence_band(n: VNode, m_new: u32) -> bool {
    pearlite! { n.stop_lbp@ <= m_new@ && m_new@ < n.m_spine@ }
}

/// Condition (2): text-region disjointness.
#[logic(open)]
pub fn cond_disjoint_region(n: VNode, edit: VEdit) -> bool {
    pearlite! { n.end@ <= edit.start@ || n.start@ >= edit.start@ + edit.removed@ }
}

/// Condition (3): tokenization-boundary agreement.
#[logic(open)]
pub fn cond_boundaries_match(n: VNode, edit: VEdit, old_src: Seq<u8>, new_src: Seq<u8>) -> bool {
    pearlite! {
        (n.start@ == 0
            || byte_at(old_src, n.start@ - 1)
                == byte_at_opt(new_src, translate_logic(edit, n.start@ - 1)))
        && byte_at(old_src, n.end@)
            == byte_at_opt(new_src, translate_logic(edit, n.end@))
    }
}

/// Condition (4): next-token left-binding-power stability.
#[logic(open)]
pub fn cond_next_token_lbp(n: VNode, edit: VEdit, new_src: Seq<u8>) -> bool {
    pearlite! {
        if n.end@ < edit.start@ {
            next_token_lbp_logic(new_src, n.end@) == n.stop_lbp@
        } else if n.end@ >= edit.start@ + edit.removed@ {
            next_token_lbp_logic(new_src, n.end@ + edit.added@ - edit.removed@) == n.stop_lbp@
        } else {
            false
        }
    }
}

