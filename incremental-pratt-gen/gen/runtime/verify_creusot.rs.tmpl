/// Logic-level next-token-lbp: skip whitespace from `pos`, return the lbp
/// of the first non-whitespace byte (0 past end-of-input).
#[logic(open)]
#[variant(src.len() - pos)]
#[requires(0 <= pos)]
pub fn next_token_lbp_logic(src: Seq<u8>, pos: Int) -> Int {
    pearlite! {
        if pos >= src.len() {
            0
        } else if src[pos] == 32u8 || src[pos] == 9u8 || src[pos] == 10u8 || src[pos] == 13u8 {
            next_token_lbp_logic(src, pos + 1)
        } else {
            lbp_of_byte_logic(src[pos])
        }
    }
}

/// Operational next-token-lbp. `#[trusted]` to match its logic model: the
/// byte-scanning loop's correspondence to `next_token_lbp_logic` is the
/// single trust assumption (it mirrors the generated runtime lexer).
#[trusted]
#[requires(pos@ <= src@.len())]
#[ensures(result@ == next_token_lbp_logic(src@, pos@))]
pub fn next_token_lbp(src: &[u8], pos: usize) -> u32 {
    let mut i = pos;
    while i < src.len() {
        let b = src[i];
        match b {
            b' ' | b'\t' | b'\n' | b'\r' => { i += 1; }
            /*@NEXT_TOKEN_LBP_OP@*/
            _ => return 0,
        }
    }
    0
}

// ---- Operational primitives with contracts -----------------------------

/// Translate an old-source position to its new-source position, or `None`
/// if inside the edited region.
#[requires(edit.start@ + edit.removed@ <= usize::MAX@)]
#[requires(old_pos@ + edit.added@ <= usize::MAX@)]
#[ensures(match result {
    Some(p) => translate_logic(edit, old_pos@) == Some(p@),
    None => translate_logic(edit, old_pos@) == None,
})]
pub fn translate_to_new(edit: VEdit, old_pos: usize) -> Option<usize> {
    if old_pos < edit.start {
        Some(old_pos)
    } else if old_pos >= edit.start + edit.removed {
        Some(old_pos + edit.added - edit.removed)
    } else {
        None
    }
}

// ---- The predicate, with full contract ----------------------------------

/// Definition 3.3: the four-part reuse predicate. Verified to equal the
/// conjunction of the four declarative conditions for `Seq<u8>` of any
/// length.
#[requires(edit.start@ + edit.removed@ <= usize::MAX@)]
#[requires(n.end@ + edit.added@ <= usize::MAX@)]
#[requires(n.start@ <= n.end@)]
#[requires(n.end@ + edit.added@ - edit.removed@ <= new_src@.len())]
#[requires(edit.start@ + edit.added@ <= new_src@.len())]
#[ensures(result == (
    cond_precedence_band(n, m_new)
    && cond_disjoint_region(n, edit)
    && cond_boundaries_match(n, edit, old_src@, new_src@)
    && cond_next_token_lbp(n, edit, new_src@)
))]
pub fn reuse_predicate(n: VNode, m_new: u32, edit: VEdit, old_src: &[u8], new_src: &[u8]) -> bool {
    // (1) precedence band
    if !(n.stop_lbp <= m_new && m_new < n.m_spine) {
        return false;
    }
    // (2) text-region disjointness
    if n.end > edit.start && n.start < edit.start + edit.removed {
        return false;
    }
    // (3) tokenization-boundary agreement
    if n.start > 0 {
        let ob = old_src.get(n.start - 1).copied();
        let nb = translate_to_new(edit, n.start - 1).and_then(|p| new_src.get(p).copied());
        if ob != nb {
            return false;
        }
    }
    let oa = old_src.get(n.end).copied();
    let na = translate_to_new(edit, n.end).and_then(|p| new_src.get(p).copied());
    if oa != na {
        return false;
    }
    // (4) next-token lbp stability
    let new_end = match translate_to_new(edit, n.end) {
        Some(p) => p,
        None => return false,
    };
    if next_token_lbp(new_src, new_end) != n.stop_lbp {
        return false;
    }
    true
}
